# -----------------------------------------------------------------------------
# Common
# -----------------------------------------------------------------------------
TZ=UTC
# 0.0.0.0 で全インターフェース待受。必要なら 192.168.0.140 などに固定。
BIND_IP=0.0.0.0

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=sake_hack_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST_PORT=5454

# -----------------------------------------------------------------------------
# Valkey
# -----------------------------------------------------------------------------
VALKEY_PASSWORD=replace-me
VALKEY_HOST_PORT=6397

# -----------------------------------------------------------------------------
# RustFS
# -----------------------------------------------------------------------------
RUSTFS_ACCESS_KEY=replace-me
RUSTFS_SECRET_KEY=replace-me
RUSTFS_API_PORT=9191
# 管理コンソールはローカルのみ公開推奨
RUSTFS_CONSOLE_BIND_IP=127.0.0.1
RUSTFS_CONSOLE_PORT=9001

# Presigned URLで利用する公開FQDN
RUSTFS_SERVER_URL=https://storage.sake-hack.com

# CORS（本番）
RUSTFS_CORS_ALLOW_ORIGIN=https://web.sake-hack.com
RUSTFS_CORS_ALLOW_METHODS=GET,PUT,HEAD,OPTIONS
RUSTFS_CORS_ALLOW_HEADERS=*
RUSTFS_CORS_EXPOSE_HEADERS=ETag
RUSTFS_CORS_ALLOW_CREDENTIALS=false
